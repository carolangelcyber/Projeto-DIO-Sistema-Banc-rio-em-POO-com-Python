class Conta:
    def __init__(self, numero, cliente, agencia="0001"):
        self.saldo = 0.0
        self.numero = numero
        self.agencia = agencia
        self.cliente = cliente
        self.historico = []  # Ajustado para lista vazia temporária

    def sacar(self, valor):
        if valor > self.saldo:
            print("Saldo insuficiente!")
            return False
        self.saldo -= valor
        return True

    def depositar(self, valor):
        if valor <= 0:
            print("Valor inválido para depósito!")
            return False
        self.saldo += valor
        return True

minha_conta = Conta(1, meu_cliente)
print(f"conta numero, {minha_conta.numero} crianda para {minha_conta.cliente.nome}!")

minha_conta.depositar(200.0)
print(f"Saldo atual da conta: R$ {minha_conta.saldo:.2f}")

